# Copy this file to `.env` and fill in the values.
# Leaving DATABASE_URL empty falls back to a local SQLite file (dev-only).

# Supabase: use the CONNECTION POOLER string (transaction mode, port 6543),
# NOT the direct connection (5432) — serverless deployments need pooled
# connections. Example:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Comma-separated list of allowed CORS origins (your frontend URLs).
ALLOWED_ORIGINS=http://localhost:3000
